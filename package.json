{
  "name": "gitpulse",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "check": "pnpm run format && pnpm run lint && pnpm run graphql:check && pnpm run typecheck",
    "graphql:schema": "cp node_modules/@octokit/graphql-schema/schema.graphql graphql/github.schema.graphql",
    "graphql:codegen": "gql.tada generate-output",
    "graphql:check": "gql.tada check -c tsconfig.graphql.json",
    "graphql:sync": "pnpm run graphql:schema && pnpm run graphql:codegen",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:tray": "node scripts/generate-tray-icons.mjs",
    "setup:oauth": "cp src-tauri/config/oauth.example.json src-tauri/config/oauth.json && echo 'Edit src-tauri/config/oauth.json — paste your GitHub OAuth Client ID'"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "~2",
    "@tauri-apps/plugin-clipboard-manager": "~2",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-http": "~2",
    "@tauri-apps/plugin-notification": "~2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "~2",
    "@tauri-apps/plugin-store": "~2",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "focus-trap": "^8.2.1",
    "gql.tada": "^1.11.2",
    "graphql": "^16.14.2",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tauri-plugin-keyring-store-api": "^0.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.17.3",
    "@egoist/tailwindcss-icons": "^1.9.2",
    "@gql.tada/vue-support": "^1.0.3",
    "@iconify-json/mdi": "^1.2.3",
    "@octokit/graphql-schema": "^15.26.1",
    "@octokit/types": "^16.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "canvas": "^3.2.3",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.10"
  }
}
