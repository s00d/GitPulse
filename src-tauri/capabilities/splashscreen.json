{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "splashscreen",
  "description": "Full permissions for the splash loader window",
  "windows": ["splashscreen"],
  "permissions": [
    "core:default",
    "opener:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*"
        },
        {
          "url": "https://*"
        }
      ],
      "deny": []
    },
    "notification:default",
    "os:default",
    "fs:default",
    "dialog:default",
    "store:default",
    "keyring-store:default",
    "iap:default"
  ]
}
